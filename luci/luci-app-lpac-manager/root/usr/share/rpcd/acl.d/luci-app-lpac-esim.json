{
  "luci-app-lpac-esim": {
    "description": "LuCI WebUI for eSIM management via lpac-esim backend",
    "read": {
      "uci": ["lpac-esim", "qmodem_esim_bot"],
      "file": {
        "/usr/bin/lpac-esim": ["exec"],
        "/usr/bin/lpac":          ["exec"],
        "/usr/sbin/qmicli":       ["exec"],
        "/sbin/logread":          ["exec"],
        "/etc/init.d/qmodem_esim_bot": ["exec"]
      }
    },
    "write": {
      "uci": ["lpac-esim", "qmodem_esim_bot"]
    }
  }
}
